.nh
.TH "AIM-REMOVE" "1" "Apr 2026" "aim " "Manage AppImages from the terminal without manual desktop setup or update juggling"

.SH NAME
aim-remove - Remove or unlink a managed AppImage


.SH SYNOPSIS
\fBaim remove  [flags]\fP


.SH DESCRIPTION
Remove or unlink a managed AppImage


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for remove

.PP
\fB--unlink\fP[=false]
	remove only desktop integration; keep managed AppImage files


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-C\fP, \fB--config\fP=
	use an alternate AIM state root

.PP
\fB--csv\fP[=false]
	output CSV where supported

.PP
\fB--dry-run\fP[=false]
	simulate changes without applying them

.PP
\fB--json\fP[=false]
	output formatted JSON

.PP
\fB--no-color\fP[=false]
	disable ANSI color output

.PP
\fB--plain\fP[=false]
	output plain tab-separated text

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	suppress non-essential status output

.PP
\fB--verbose\fP[=false]
	enable verbose diagnostic logging

.PP
\fB-y\fP, \fB--yes\fP[=false]
	skip confirmation prompts


.SH EXAMPLE
.EX
aim remove example-app
  aim remove --unlink example-app
  aim remove --dry-run example-app --json
.EE


