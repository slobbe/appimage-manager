.nh
.TH "AIM-UPDATE-SET" "1" "Apr 2026" "aim " "Manage AppImages from the terminal without manual desktop setup or update juggling"

.SH NAME
aim-update-set - Set the update source for a managed AppImage


.SH SYNOPSIS
\fBaim update set  [flags]\fP


.SH DESCRIPTION
Set the update source for a managed AppImage


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for set


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--asset\fP=""
	asset filename pattern; defaults to "*.AppImage" for GitHub/GitLab (for 'update set')

.PP
\fB-c\fP, \fB--check-only\fP[=false]
	check only; do not apply updates

.PP
\fB-C\fP, \fB--config\fP=
	use an alternate AIM state root

.PP
\fB--csv\fP[=false]
	output CSV where supported

.PP
\fB--dry-run\fP[=false]
	simulate changes without applying them

.PP
\fB--embedded\fP[=false]
	use the update source embedded in the current AppImage (for 'update set')

.PP
\fB--github\fP=
	GitHub repo in the form owner/repo (for 'update set')

.PP
\fB--gitlab\fP=
	GitLab project path namespace/project (for 'update set')

.PP
\fB--json\fP[=false]
	output formatted JSON

.PP
\fB--no-color\fP[=false]
	disable ANSI color output

.PP
\fB--plain\fP[=false]
	output plain tab-separated text

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	suppress non-essential status output

.PP
\fB--verbose\fP[=false]
	enable verbose diagnostic logging

.PP
\fB-y\fP, \fB--yes\fP[=false]
	skip confirmation prompts

.PP
\fB--zsync\fP=
	direct zsync metadata URL (https, for 'update set')


.SH EXAMPLE
.EX
aim update set example-app --github owner/repo
  aim update set example-app --embedded
  aim update set example-app --zsync https://example.com/Example.AppImage.zsync --dry-run --json
.EE


