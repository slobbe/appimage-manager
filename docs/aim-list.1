.nh
.TH "AIM-LIST" "1" "Apr 2026" "aim " "Manage AppImages from the terminal without manual desktop setup or update juggling"

.SH NAME
aim-list - List managed AppImages


.SH SYNOPSIS
\fBaim list [flags]\fP


.SH DESCRIPTION
List managed AppImages


.SH OPTIONS
\fB-a\fP, \fB--all\fP[=false]
	list all AppImages (default)

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for list

.PP
\fB--integrated\fP[=false]
	list integrated AppImages only

.PP
\fB--unlinked\fP[=false]
	list unlinked AppImages only


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--csv\fP[=false]
	output CSV where supported

.PP
\fB-d\fP, \fB--debug\fP[=false]
	enable diagnostic logging

.PP
\fB-n\fP, \fB--dry-run\fP[=false]
	simulate changes without applying them

.PP
\fB--json\fP[=false]
	output formatted JSON

.PP
\fB--no-color\fP[=false]
	disable ANSI color output

.PP
\fB--no-input\fP[=false]
	disable interactive prompts

.PP
\fB--plain\fP[=false]
	output plain tab-separated text

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	suppress non-essential status output

.PP
\fB-y\fP, \fB--yes\fP[=false]
	skip confirmation prompts


.SH EXAMPLE
.EX
aim list
  aim list --integrated
  aim list --json
  aim list --csv
.EE


