.nh
.TH "AIM" "1" "Apr 2026" "aim dev" "Manage AppImages from the terminal without manual desktop setup or update juggling"

.SH NAME
aim - Manage AppImages from the terminal without manual desktop setup or update juggling


.SH SYNOPSIS
\fBaim [flags]\fP


.SH DESCRIPTION
Install, integrate, update, and remove AppImages from one terminal tool.


.SH OPTIONS
\fB-C\fP, \fB--config\fP=
	use an alternate AIM state root

.PP
\fB--csv\fP[=false]
	output CSV where supported

.PP
\fB-d\fP, \fB--debug\fP[=false]
	enable diagnostic logging

.PP
\fB-n\fP, \fB--dry-run\fP[=false]
	simulate changes without applying them

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for aim

.PP
\fB--json\fP[=false]
	output formatted JSON

.PP
\fB--no-color\fP[=false]
	disable ANSI color output

.PP
\fB--no-input\fP[=false]
	disable interactive prompts

.PP
\fB--plain\fP[=false]
	output plain tab-separated text

.PP
\fB-q\fP, \fB--quiet\fP[=false]
	suppress non-essential status output

.PP
\fB--upgrade\fP[=false]
	upgrade aim via the official installer

.PP
\fB-v\fP, \fB--version\fP[=false]
	version for aim

.PP
\fB-y\fP, \fB--yes\fP[=false]
	skip confirmation prompts


.SH EXAMPLE
.EX
aim --help
  aim --version
  aim --json
  aim -C /tmp/aim-state list --json
  aim add -n ./Example.AppImage
  aim update --yes
.EE


